# greenmile_sync worker - configuration template
# The executable can create this file automatically through the local hacker panel.
# NEVER commit .env to version control.

# Apps Script URL is fixed inside the executable.
# Only the token is editable here.
APPS_SCRIPT_TOKEN=your-secret-token-here

# GreenMile API
GREENMILE_URL=https://3coracoes.greenmile.com
GREENMILE_USERNAME=seu.usuario@email.com
GREENMILE_PASSWORD=sua_senha_aqui

# Optional behavior
CHUNK_SIZE=50
REQUEST_TIMEOUT=30
MAX_RETRIES=3
